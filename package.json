{
  "name": "nextjs-starter-template",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint src --ext .ts,.tsx --cache",
    "lint:fix": "eslint src --ext .ts,.tsx --fix --cache",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,json,md,mdx}\"",
    "format:write": "prettier --write \"**/*.{js,jsx,ts,tsx,css,json,md,mdx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "knip": "knip",
    "codehawk": "codehawk src",
    "clean": "node scripts/clean.mjs",
    "install:npm": "npm ci",
    "install:yarn": "yarn install --frozen-lockfile",
    "install:pnpm": "pnpm install --frozen-lockfile",
    "install:bun": "bun install --frozen-lockfile || bun install",
    "docker:build": "docker build -t nextjs-starter-template .",
    "docker:run": "docker run --env-file .env.local -p 3000:3000 nextjs-starter-template",
    "docker:up": "docker compose up --build",
    "docker:up:db": "docker compose --profile db up --build",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.10",
    "@reduxjs/toolkit": "^2.9.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "^16.0.1",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "react-redux": "^9.2.0",
    "react-scan": "^0.5.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@storybook/nextjs": "^10.3.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.1.2",
    "codehawk-cli": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.1.0",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^29.0.1",
    "knip": "^6.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{css,json,md,mdx}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "eslint": "10.1.0"
  }
}
